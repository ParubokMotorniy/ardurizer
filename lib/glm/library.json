{
  "name": "glm",
  "version": "1.1.0",
  "description": "OpenGL Mathematics header-only C++ mathematics library packaged for PlatformIO.",
  "keywords": [
    "math",
    "vector",
    "matrix",
    "quaternion",
    "graphics"
  ],
  "authors": [
    {
      "name": "G-Truc Creation"
    }
  ],
  "license": "MIT",
  "frameworks": "*",
  "platforms": "*",
  "headers": [
    "glm.hpp"
  ],
  "build": {
    "flags": [
      "-DGLM_FORCE_CXX17",
      "-DGLM_FORCE_PURE",
      "-DGLM_FORCE_SILENT_WARNINGS"
    ],
    "includeDir": ".",
    "srcFilter": [
      "-<*>"
    ]
  }
}
